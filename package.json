{
  "name": "dom2md-chrome-ext",
  "version": "1.0.0",
  "description": "Convert selected DOM elements to Markdown instantly from Chrome DevTools.",
  "main": "index.js",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js",
    "watch": "tsc --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,html}\" \"*.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,html}\" \"*.json\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "chrome-extension",
    "devtools",
    "markdown",
    "dom",
    "turndown"
  ],
  "author": "Zhicheng Wang",
  "license": "MIT",
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "dependencies": {
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.1.42",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
