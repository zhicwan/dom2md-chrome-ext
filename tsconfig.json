{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": false,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "types": ["chrome"]
  },
  "include": ["src/**/*.ts"]
}
