{
  "manifest_version": 3,
  "key": "",
  "name": "DOM2MD",
  "version": "1.0.2",
  "description": "Convert selected DOM elements to Markdown instantly from Chrome DevTools.",
  "devtools_page": "devtools.html",
  "minimum_chrome_version": "88",
  "permissions": ["clipboardWrite"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
